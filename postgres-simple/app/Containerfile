FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY seed.py app.py ./

ENTRYPOINT ["tini", "--"]
CMD ["sh", "-c", "python -u seed.py && python -u app.py"]
